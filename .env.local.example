# Copy to .env.local and fill in. Never commit .env.local.

# Supabase project (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: service role key (used by the allowlist gate / server routes). Keep secret.
SUPABASE_SERVICE_ROLE_KEY=

# Auth gate (US-1): owner-override recovery email so a bad first login can't lock Javi out.
OWNER_OVERRIDE_EMAIL=

# Optional: shared secret the Vercel cron sends to /api/health to keep Supabase warm.
HEALTH_PING_SECRET=
