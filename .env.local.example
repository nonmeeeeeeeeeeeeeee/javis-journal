# Browser Supabase project URL.
NEXT_PUBLIC_SUPABASE_URL=

# Browser Supabase publishable key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server Supabase project URL.
SUPABASE_URL=

# Server Supabase secret key for trusted server-side operations.
SUPABASE_SECRET_KEY=

# Recovery email that bypasses the allowlist gate.
OWNER_OVERRIDE_EMAIL=

# Bearer token used by Vercel Cron for /api/health.
CRON_SECRET=
